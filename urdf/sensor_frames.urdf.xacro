<?xml version="1.0"?>
<!--
  Sensor Frame Definitions for ros2_wit_d435
  
  Defines the TF tree for the D435i camera and WitMotion WT901 IMU
  relative to base_link. All offsets are parameterized so each robot
  platform can override them without modifying this file.

  Usage in launch:
    xacro sensor_frames.urdf.xacro
          cam_x:=0.15 cam_y:=0.0 cam_z:=0.20
          cam_roll:=0.0 cam_pitch:=0.0 cam_yaw:=0.0
          imu_x:=0.0 imu_y:=0.0 imu_z:=0.05
          imu_roll:=0.0 imu_pitch:=0.0 imu_yaw:=0.0
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sensor_frames">

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- Parameters (override per platform via launch args)                 -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->

  <!-- Camera mount position relative to base_link -->
  <xacro:arg name="cam_x"     default="0.15"/>
  <xacro:arg name="cam_y"     default="0.0"/>
  <xacro:arg name="cam_z"     default="0.20"/>
  <xacro:arg name="cam_roll"  default="0.0"/>
  <xacro:arg name="cam_pitch" default="0.0"/>
  <xacro:arg name="cam_yaw"   default="0.0"/>

  <!-- IMU mount position relative to base_link -->
  <xacro:arg name="imu_x"     default="0.0"/>
  <xacro:arg name="imu_y"     default="0.0"/>
  <xacro:arg name="imu_z"     default="0.05"/>
  <xacro:arg name="imu_roll"  default="0.0"/>
  <xacro:arg name="imu_pitch" default="0.0"/>
  <xacro:arg name="imu_yaw"   default="0.0"/>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- Links                                                               -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->

  <!-- Base link (provided by platform-specific node or this default) -->
  <link name="base_link"/>

  <!-- Base footprint (ground plane projection) -->
  <link name="base_footprint"/>

  <!-- Camera link (D435i body frame) -->
  <link name="camera_link"/>

  <!-- IMU link (WitMotion WT901) -->
  <link name="imu_link"/>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- Joints (static transforms)                                         -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->

  <!-- base_footprint → base_link (ground to robot center) -->
  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- base_link → camera_link -->
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="$(arg cam_x) $(arg cam_y) $(arg cam_z)"
            rpy="$(arg cam_roll) $(arg cam_pitch) $(arg cam_yaw)"/>
  </joint>

  <!-- base_link → imu_link -->
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="$(arg imu_x) $(arg imu_y) $(arg imu_z)"
            rpy="$(arg imu_roll) $(arg imu_pitch) $(arg imu_yaw)"/>
  </joint>

</robot>
